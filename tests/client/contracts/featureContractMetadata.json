          "reverseSpecPath": "docs/reverse-specs/admin-overview-dashboard-reverse-spec.md",
          "status": "done",
          "criticalInvariants": [
            "Remote overview data merges with fallback model per section instead of all-or-nothing replacement.",
            "Overview export reflects the currently normalized and sorted client-visible rows.",
            "Session cache can seed first paint and refresh in place without leaving the overview shell."
          ],
          "targetedChecks": [
            "npm run test:client:smoke -- admin-control-center"
          ]
        },
        {
          "id": "admin-analytics-dashboard",
