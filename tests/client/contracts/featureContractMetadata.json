          "status": "done",
          "criticalInvariants": [
            "Summary and month-detail requests stay independently cached and basis-month changes do not force a summary refetch.",
            "Analytics keeps the last visible dataset rendered while a compatible refresh is in flight.",
            "Export uses the normalized analytics model rather than raw server payload fragments."
          ],
          "targetedChecks": [
            "npm run test:client:smoke -- admin-control-center"
          ]
        },
        {
          "id": "admin-photo-admin-flow",
          "goal": "Protect the admin photo section as a recoverable slice on top of the shared photo album and download/upload path.",
