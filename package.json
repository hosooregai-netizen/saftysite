{
  "name": "saftysite-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/contracts",
    "packages/prompt-packs",
    "packages/report-engine",
    "packages/template-assets"
  ],
  "scripts": {
    "rundev": "node scripts/rundev.mjs",
    "dev": "node scripts/rundev.mjs",
    "dev:erp": "node scripts/rundev.mjs",
    "dev:saas": "node scripts/dev.mjs",
    "dev:sass": "npm run dev:saas",
    "dev:web": "npm run dev -w @saftysite/web",
    "dev:legacy": "node scripts/rundev.mjs",
    "build": "npm run build -w @saftysite/web",
    "build:web": "npm run build -w @saftysite/web",
    "start": "npm run start -w @saftysite/web",
    "start:web": "npm run start -w @saftysite/web",
    "prepare": "node scripts/installGitHooks.mjs",
    "lint": "npm run lint -w @saftysite/web && npm run lint -w @saftysite/contracts",
    "lint:legacy": "eslint .",
    "test": "npm run test -w @saftysite/contracts",
    "contracts:schemas": "npm run generate:schemas -w @saftysite/contracts",
    "test:domain:bad-workplace": "tsx tests/domain/badWorkplace.domain.ts",
    "test:client:smoke": "tsx tests/client/runSmoke.ts",
    "test:client:smoke:headed": "PLAYWRIGHT_HEADLESS=0 tsx tests/client/runSmoke.ts",
    "test:client:feature": "tsx tests/client/runSmoke.ts",
    "aidlc:audit": "node scripts/aidlcAudit.mjs",
    "aidlc:audit:strict": "node scripts/aidlcAudit.mjs --strict",
    "aidlc:audit:admin": "node scripts/aidlcAudit.mjs --scope admin",
    "aidlc:audit:admin:strict": "node scripts/aidlcAudit.mjs --scope admin --strict",
    "verify:aidlc": "node scripts/verifyAidlc.mjs",
    "verify:aidlc:push": "node scripts/verifyAidlcPush.mjs",
    "hooks:install": "node scripts/installGitHooks.mjs",
    "smoke:erp": "tsx scripts/smokeClient.ts",
    "smoke:real:admin": "tsx scripts/smokeRealAdmin.ts",
    "benchmark:mail-send": "tsx scripts/benchmarkMailSend.ts",
    "smoke:real:admin:safe": "tsx scripts/smokeSafeAdmin.ts",
    "verify:erp-live": "tsx scripts/verifyErpLiveContracts.ts",
    "probe:api-live": "tsx scripts/probeSafetyApiLive.ts",
    "verify:api-live-budgets": "tsx scripts/probeSafetyApiLive.ts --enforce-budgets",
    "generate:service-intro": "tsx scripts/generateServiceIntro.ts",
    "import:hazard-countermeasure": "python scripts/import_hazard_countermeasure_catalog.py",
    "capture:naver-review": "tsx scripts/captureNaverReview.ts",
    "capture:google-review": "tsx scripts/captureGoogleReview.ts",
    "generate:hwpx": "node --experimental-strip-types scripts/generate_hwpx_report.ts",
    "bootstrap:hwpx-template": "node --experimental-strip-types scripts/bootstrap_inspection_hwpx_template.ts",
    "seed:measurement-templates": "node --experimental-strip-types scripts/seed_measurement_templates.ts",
    "api:dev": "node scripts/api-dev.mjs",
    "api:check": "python3 -m compileall apps/api/app"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "fast-xml-parser": "^5.5.10",
    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "next": "16.1.6",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "text-to-svg": "^3.1.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "playwright": "^1.53.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "zod-to-json-schema": "^3.24.6"
  }
}
