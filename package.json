{
  "name": "korea-safety",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "rundev": "node scripts/rundev.mjs",
    "dev": "node scripts/rundev.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "prepare": "node scripts/installGitHooks.mjs",
    "lint": "eslint .",
    "test:client:smoke": "tsx tests/client/runSmoke.ts",
    "test:client:smoke:headed": "PLAYWRIGHT_HEADLESS=0 tsx tests/client/runSmoke.ts",
    "test:client:feature": "tsx tests/client/runSmoke.ts",
    "test:pr": "node scripts/testClientSuites.mjs pr",
    "test:nightly": "node scripts/testClientSuites.mjs nightly",
    "test:scope": "node scripts/testClientSuites.mjs scope",
    "aidlc:audit": "node scripts/aidlcAudit.mjs",
    "aidlc:audit:strict": "node scripts/aidlcAudit.mjs --strict",
    "aidlc:audit:admin": "node scripts/aidlcAudit.mjs --scope admin",
    "aidlc:audit:admin:strict": "node scripts/aidlcAudit.mjs --scope admin --strict",
    "verify:aidlc": "node scripts/verifyAidlc.mjs",
    "verify:aidlc:push": "node scripts/verifyAidlcPush.mjs",
    "hooks:install": "node scripts/installGitHooks.mjs",
    "smoke:erp": "tsx scripts/smokeClient.ts",
    "smoke:real:admin": "tsx scripts/smokeRealAdmin.ts",
    "smoke:real:client": "tsx scripts/smokeRealClient.ts",
    "verify:erp-live": "tsx scripts/verifyErpLiveContracts.ts",
    "probe:api-live": "tsx scripts/probeSafetyApiLive.ts",
    "generate:service-intro": "tsx scripts/generateServiceIntro.ts",
    "capture:naver-review": "tsx scripts/captureNaverReview.ts",
    "capture:google-review": "tsx scripts/captureGoogleReview.ts",
    "generate:hwpx": "node --experimental-strip-types scripts/generate_hwpx_report.ts",
    "bootstrap:hwpx-template": "node --experimental-strip-types scripts/bootstrap_inspection_hwpx_template.ts",
    "seed:measurement-templates": "node --experimental-strip-types scripts/seed_measurement_templates.ts",
    "legacy:tg:manifest": "python3 -m scripts.legacy_insafed.build_technical_guidance_manifest",
    "legacy:tg:evidence": "python3 -m scripts.legacy_insafed.extract_technical_guidance_evidence",
    "legacy:tg:canonical": "python3 -m scripts.legacy_insafed.build_technical_guidance_canonical",
    "legacy:tg:variant-profiles": "python3 -m scripts.legacy_insafed.build_technical_guidance_variant_profiles",
    "legacy:tg:draft": "node --import tsx scripts/legacy_insafed/generate_technical_guidance_draft.ts",
    "legacy:tg:validate-format": "python3 -m scripts.legacy_insafed.validate_technical_guidance_format",
    "legacy:tg:image-sample": "python3 -m scripts.legacy_insafed.build_image_only_pdf_sample",
    "legacy:tg:ordered-mix": "python3 -m scripts.legacy_insafed.build_ordered_mixed_image_pdf",
    "legacy:tg:photo-request": "python3 -m scripts.legacy_insafed.build_technical_guidance_photo_request"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "fast-xml-parser": "^5.5.10",
    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "next": "16.1.6",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "playwright": "^1.53.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
